generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id          Int      @id @default(autoincrement())
  title       String
  location    String
  description String
  type        String
  createdAt   DateTime @default(now())
}

model Application {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String
  position    String?
  coverLetter String?
  resumeUrl   String?
  createdAt   DateTime @default(now())
}